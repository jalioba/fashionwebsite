{
  "name": "avishu-platform",
  "version": "1.0.0",
  "description": "AVISHU Clothing Manufacturer — Web Platform",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "dev:ai": "cd ai && uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "dev:react": "cd react-app && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:ai\" \"npm run dev:react\"",
    "build:react": "cd react-app && npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "private": true,
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "package.json": "^2.0.1",
    "three": "^0.183.2",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
